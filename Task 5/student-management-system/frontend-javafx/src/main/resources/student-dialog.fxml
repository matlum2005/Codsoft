<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets ?>
<?import javafx.scene.control.* ?>
<?import javafx.scene.layout.* ?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.studentmgmt.controller.StudentDialogController" spacing="15.0" stylesheets="@styles.css">
   <children>
      <GridPane hgap="10.0" vgap="10.0" HBox.hgrow="ALWAYS">
         <children>
            <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="nameField" promptText="Enter student name" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <Label text="Roll Number:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="rollNumberField" promptText="Enter roll number" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="emailField" promptText="Enter email" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label text="Age:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="ageField" promptText="Enter age (18+)" GridPane.columnIndex="1" GridPane.rowIndex="3" />
         </children>
         <columnConstraints>
            <ColumnConstraints hgrow="NEVER" minWidth="100.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" />
         </columnConstraints>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </GridPane>
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button fx:id="saveButton" mnemonicParsing="false" onAction="#saveStudent" text="Save" />
            <Button fx:id="cancelButton" mnemonicParsing="false" onAction="#cancel" text="Cancel" />
         </children>
      </HBox>
   </children>
</VBox>
