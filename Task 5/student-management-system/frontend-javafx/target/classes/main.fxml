<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets ?>
<?import javafx.scene.control.* ?>
<?import javafx.scene.layout.* ?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.studentmgmt.controller.MainController"
      prefHeight="600.0" prefWidth="900.0" spacing="10.0" stylesheets="@styles.css">
   <children>
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Label text="Student Management System" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
         </children>
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </HBox>

      <HBox spacing="10.0" HBox.hgrow="NEVER">
         <children>
            <Label text="Search: " />
            <TextField fx:id="searchField" prefWidth="200.0" promptText="Enter name, roll no, or email" />
            <Button fx:id="searchButton" mnemonicParsing="false" onAction="#searchStudents" text="Search" />
            <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#loadStudents" text="Refresh" />
         </children>
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="0.0" />
         </padding>
      </HBox>

      <TableView fx:id="studentTable" prefHeight="400.0" prefWidth="860.0" VBox.vgrow="ALWAYS">
         <columns>
            <TableColumn fx:id="idColumn" prefWidth="60.0" text="ID" />
            <TableColumn fx:id="nameColumn" prefWidth="150.0" text="Name" />
            <TableColumn fx:id="rollNumberColumn" prefWidth="120.0" text="Roll No" />
            <TableColumn fx:id="emailColumn" minWidth="200.0" text="Email" />
            <TableColumn fx:id="ageColumn" prefWidth="80.0" text="Age" />
         </columns>
         <padding>
            <Insets bottom="0.0" left="20.0" right="20.0" top="0.0" />
         </padding>
      </TableView>

      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button fx:id="addButton" mnemonicParsing="false" onAction="#addStudent" text="Add Student" />
            <Button fx:id="updateButton" mnemonicParsing="false" onAction="#updateStudent" text="Update" />
            <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#deleteStudent" text="Delete" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </HBox>
   </children>
</VBox>
